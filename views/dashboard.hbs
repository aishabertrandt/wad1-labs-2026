{{> menu id="dashboard"}}

<section class="ui left aligned middle aligned segment">
  
  <h2>Aisha's App Dashboard</h2>
  
  {{#unless playlists}}
    <h3 class="ui message">
      Start adding your book collections!
    </h3>
  {{/unless}}

  {{#each playlists}}
    <section class="ui left aligned middle aligned segment">

      <h3 class="ui header">
        {{title}}
      </h3>
     <a href="/playlist/{{id}}"> View </a>

    </section>
  {{/each}}

</section>
 